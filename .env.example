# ----------------------------------------------------------------------------
# InstaAuto Backend — variáveis de ambiente
# Copie para .env (local) ou configure no Railway (produção).
# ----------------------------------------------------------------------------

# Postgres. No Railway, referencie a variável do serviço Postgres:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://user:pass@host:5432/instauto"

NODE_ENV=production
PORT=3001

# --- Auth ---
# Gere um segredo forte: openssl rand -base64 48
JWT_SECRET="troque-por-um-segredo-forte"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL_DAYS=30

# Passphrase para cifrar tokens da Meta (AES-256-GCM). Gere um valor forte e
# NÃO troque depois de ter tokens salvos (invalidaria os existentes).
INTEGRATION_ENC_KEY="troque-por-uma-passphrase-forte"

# --- CORS ---
# URL pública do frontend.
FRONTEND_URL="https://seu-frontend.up.railway.app"
# Origens extras separadas por vírgula (opcional).
CORS_ALLOWED_ORIGINS=""

# --- Meta Graph API ---
META_GRAPH_VERSION="v22.0"
# App ID e App Secret do seu app em developers.facebook.com (App Settings → Basic).
# Usados no fluxo Facebook Login.
META_APP_ID=""
META_APP_SECRET=""
# Credenciais do fluxo Instagram Login — SÃO DIFERENTES das de cima.
# Em: Instagram → API setup with Instagram login → Business login settings.
# Se ficarem vazias, o backend usa META_APP_ID/SECRET (que NÃO funciona no
# fluxo Instagram — erro "Invalid platform app").
META_INSTAGRAM_APP_ID=""
META_INSTAGRAM_APP_SECRET=""
# Base do callback. O backend acrescenta ?provider=instagram|facebook
# automaticamente. Cadastre AMBAS as variantes como Redirect URI no app Meta:
#   .../api/accounts/callback?provider=instagram
#   .../api/accounts/callback?provider=facebook
META_OAUTH_REDIRECT_URI="https://seu-backend.up.railway.app/api/accounts/callback"
# Token livre que você define e repete no painel de webhooks da Meta.
META_WEBHOOK_VERIFY_TOKEN="defina-um-token-de-verificacao"
